{
  "name": "estimat",
  "private": true,
  "workspaces": ["shared", "server", "client"],
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w shared && npm run build -w server && npm run build -w client",
    "typecheck": "npm run typecheck -w shared && npm run typecheck -w server && npm run typecheck -w client",
    "test:material-grouping": "node --import tsx --test \"shared/src/constants/*.test.ts\" \"client/src/pages/contractors/materials/*.test.ts\" \"server/src/lib/material-grouping/*.test.ts\" \"server/src/lib/llm/*.test.ts\"",
    "test:tables": "node --import tsx --test \"client/src/lib/*.test.ts\" \"client/src/pages/requests/*.test.ts\" \"client/src/pages/requests/supplierOrder/*.test.ts\" \"server/src/lib/requests/*.test.ts\" \"server/src/lib/contractors/*.test.ts\" \"server/src/lib/procurement/*.test.ts\" \"server/src/lib/supplier-orders/*.test.ts\" \"server/src/lib/invoice-recognition/*.test.ts\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  }
}
