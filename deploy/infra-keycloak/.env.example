# Keycloak (infra) — пример окружения. Скопировать в .env и заполнить реальными значениями.
# .env НЕ коммитится в git (§18). Секреты хранятся в защищённом storage (Yandex Lockbox /
# файл с правами 640 root:docker), значения не выводятся в логи и чат.

# --- Версия образа (pin, не latest) ---
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.1

# --- БД keycloak_db (Yandex Managed PostgreSQL, отдельный пользователь, TLS) ---
# Порт Yandex обычно 6432. sslmode=require (или verify-full с CA — см. README).
KC_DB_URL=jdbc:postgresql://c-<cluster-id>.rw.mdb.yandexcloud.net:6432/keycloak_db?ssl=true&sslmode=require
KC_DB_USERNAME=keycloak_runtime
KC_DB_PASSWORD=<keycloak-db-password>

# --- Hostname / issuer ---
KC_HOSTNAME=https://auth.su10.ru
KC_HOSTNAME_ADMIN=https://auth-admin.su10.ru

# --- Bootstrap-админ (ВРЕМЕННЫЙ). После создания постоянного админа удалить bootstrap-учётку
#     и убрать эти переменные из .env (§9). ---
KC_BOOTSTRAP_ADMIN_USERNAME=bootstrap-admin
KC_BOOTSTRAP_ADMIN_PASSWORD=<strong-bootstrap-password>
