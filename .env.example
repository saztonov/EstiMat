# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=estimat
DB_USER=estimat
DB_PASSWORD=estimat_secret
DB_SSL=false
# Для Yandex Managed PostgreSQL:
# DB_HOST=c-<cluster-id>.rw.mdb.yandexcloud.net
# DB_PORT=6432
# DB_SSL=true

# JWT
JWT_SECRET=change-me-to-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-to-another-random-string-32-chars

# CORS
CORS_ORIGIN=http://localhost:5173

# S3 (Cloud.ru)
S3_ENDPOINT=https://s3.cloud.ru
S3_REGION=ru-central-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=estimat-files

# Портал РД (RDLOCAL, только чтение) — необязательно.
# Без этих переменных секция «Рабочая документация» показывает «не настроено».
# Supabase: URL проекта и API-ключ (anon или service role).
RD_SUPABASE_URL=
RD_SUPABASE_KEY=
# Cloudflare R2 (S3-совместимый), значения те же, что в env RDLOCAL:
# R2_ENDPOINT_URL / R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY / R2_BUCKET_NAME
RD_R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
RD_R2_ACCESS_KEY_ID=
RD_R2_SECRET_ACCESS_KEY=
RD_R2_BUCKET=

# Встроенный ИИ-извлекатель из РД (фаза 2) — необязательно. Тот же ключ/URL использует и ИИ-чат.
# Без ключа POST /api/ai/jobs только создаёт задание, его выполняет skill estimate-extract.
# С ключом задание извлекается сразу в фоне дешёвой моделью OpenRouter.
#
# Вариант А (по умолчанию) — напрямую в OpenRouter: API-ключ OpenRouter + его base URL.
# Вариант Б — через прокси proxy_llm (изоляция ключа, журнал, алерты):
#   AI_OPENROUTER_BASE_URL=https://proxyllm.fvds.ru/api/v1
#   AI_OPENROUTER_API_KEY=<PROXY_INBOUND_TOKEN прокси>   # это токен прокси, НЕ ключ OpenRouter
#   При работе через прокси значение AI_OPENROUTER_MODEL не действует — модель задаёт прокси.
AI_OPENROUTER_API_KEY=
AI_OPENROUTER_MODEL=google/gemini-2.5-flash
AI_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Собственный сервер моделей LM Studio (OpenAI-совместимый) — для ИИ-чата/извлечения РД.
# Используется, когда в Администрировании выбрана модель этого сервера (lmstudio:<id>).
# Адрес можно переопределить в Администрировании → «Сервер моделей»; ниже — значение по умолчанию.
# Токен (LMSTUDIO_API_KEY) — СЕКРЕТ: только в env, не коммитить.
LMSTUDIO_BASE_URL=https://01.vibe.cloud-ip.cc/v1
LMSTUDIO_API_KEY=
# LMSTUDIO_ALLOWED_HOSTS=01.vibe.cloud-ip.cc   # доп. разрешённые хосты для адреса из БД (SSRF-защита)
# LMSTUDIO_MAX_TOKENS=8192
# LMSTUDIO_MAX_CONCURRENCY=1                    # у Qwen worker=1

# Интеграция с BillHub (заявки на оплату по РП) — необязательно.
# BILLHUB_BASE_URL / BILLHUB_API_TOKEN: адрес и сервисный токен BillHub (исходящее направление).
#   Без них форма заявки на оплату работает в режиме черновика (в BillHub не отправляет).
# BILLHUB_SYNC_ENABLED: отдельный рубильник отправки (по умолчанию выкл.) — включать после
#   готовности стороны BillHub.
# INTEGRATION_API_KEY: ключ для приёма ВХОДЯЩИХ событий от BillHub (≥32 симв.). СЕКРЕТ — только env.
BILLHUB_BASE_URL=
BILLHUB_API_TOKEN=
BILLHUB_SYNC_ENABLED=false
# BILLHUB_TIMEOUT_MS=15000
INTEGRATION_API_KEY=

# Интеграция с тендерным порталом СУ-10 (закупочные лоты → площадка) — необязательно.
# TENDER_BASE_URL / TENDER_API_TOKEN: origin портала (https в проде, без пути) и сервисный Bearer-токен (СЕКРЕТ).
# TENDER_SYNC_ENABLED: рубильник отправки/опроса — включать после готовности стороны портала.
# TENDER_MOCK: встроенная заглушка портала для локального теста (тендер сразу «завершается» с победителем);
#   ТОЛЬКО dev — в production запрещена. Работает без TENDER_BASE_URL/TOKEN и без рубильника.
TENDER_BASE_URL=
TENDER_API_TOKEN=
TENDER_SYNC_ENABLED=false
TENDER_MOCK=false
# TENDER_TIMEOUT_MS=15000

# Server
PORT=3000
NODE_ENV=development
