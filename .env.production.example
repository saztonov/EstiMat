# EstiMat — production окружение (single-VPS baseline).
# Скопируйте в /etc/estimat/estimat.env на VPS, заполните реальными значениями:
#   sudo install -m 640 -o root -g docker .env.production.example /etc/estimat/estimat.env
# Это host-specific конфиг (FHS /etc), его читает env_file в compose и deploy-estimat.
# НЕ коммитить реальные значения; секреты — в защищённом хранилище (§18).

NODE_ENV=production
PORT=3000

# --- Yandex Managed PostgreSQL (§7). TLS обязателен. ---
DB_HOST=c-<cluster-id>.rw.mdb.yandexcloud.net
DB_PORT=6432
DB_NAME=estimat
DB_USER=estimat_runtime
DB_PASSWORD=<сильный-пароль-runtime-пользователя>
DB_SSL=true
# Размер пула соединений (§7). Учитывайте в connection budget Managed PG:
# суммарно по всем порталам conn_limit ≤ max_connections − резервы.
DB_POOL_MAX=20
# Примечание: миграции накатываются отдельным шагом пользователем estimat_migration (DDL).
# Если runtime-пользователь без DDL-прав — для шага migrate используйте отдельный .env
# с DB_USER=estimat_migration или временно повысьте права.

# --- JWT (standalone auth, §13). Сгенерируйте случайные строки ≥ 32 символов: ---
#   openssl rand -base64 48
JWT_SECRET=<random-min-32-chars>
JWT_REFRESH_SECRET=<random-min-32-chars-другой>

# --- CORS (§23): origin фронтенда (раздельные домены app.* / api.*). ---
CORS_ORIGIN=https://app.estimat.example

# --- S3 Cloud.ru (§15): хранение файлов (обложки проектов и пр.). Обязательно в проде. ---
S3_ENDPOINT=https://s3.cloud.ru
S3_REGION=ru-central-1
S3_ACCESS_KEY=<access-key>
S3_SECRET_KEY=<secret-key>
S3_BUCKET=estimat-files

# --- Портал РД (RDLOCAL, read-only) — опционально (§ интеграции). ---
RD_SUPABASE_URL=
RD_SUPABASE_KEY=
RD_R2_ENDPOINT=
RD_R2_ACCESS_KEY_ID=
RD_R2_SECRET_ACCESS_KEY=
RD_R2_BUCKET=

# --- ИИ-извлекатель из РД + ИИ-чат — опционально. ---
# В проде LLM-вызовы идут через прокси proxy_llm (изоляция ключа OpenRouter, журнал, алерты):
#   AI_OPENROUTER_BASE_URL=https://proxyllm.fvds.ru/api/v1
#   AI_OPENROUTER_API_KEY=<PROXY_INBOUND_TOKEN прокси>   # токен прокси (общий с PassDesk), НЕ ключ OpenRouter
# Модель определяет сам прокси (OPENROUTER_MODEL на стороне proxy_llm) — значение AI_OPENROUTER_MODEL
# ниже при работе через прокси не действует, но должно остаться непустым.
# Чтобы временно ходить в OpenRouter напрямую: base URL = https://openrouter.ai/api/v1, ключ = ключ OpenRouter.
AI_OPENROUTER_API_KEY=
AI_OPENROUTER_MODEL=google/gemini-2.5-flash
AI_OPENROUTER_BASE_URL=https://proxyllm.fvds.ru/api/v1

# --- Собственный сервер моделей LM Studio (OpenAI-совместимый) — опционально. ---
# Используется, когда в Администрировании выбрана модель этого сервера (lmstudio:<id>).
# Адрес правится в Администрировании → «Сервер моделей» (хранится в БД); ниже — fallback и
# базовый allowlist хостов. Токен — СЕКРЕТ: только env, не коммитить.
LMSTUDIO_BASE_URL=https://01.vibe.cloud-ip.cc/v1
LMSTUDIO_API_KEY=
# Доп. разрешённые хосты для адреса из БД (через запятую). По умолчанию разрешён только хост
# из LMSTUDIO_BASE_URL — защита от SSRF/утечки токена при правке адреса в админке.
# LMSTUDIO_ALLOWED_HOSTS=
# LMSTUDIO_MAX_TOKENS=8192
# LMSTUDIO_MAX_CONCURRENCY=1
# LMSTUDIO_TIMEOUT_MS=120000

# --- Origin backend API ---
# Абсолютный origin API. Используется как build-arg фронта (deploy-estimat экспортирует
# его автоматически) и как цель health-check. Раздельные домены: app.* (SPA) / api.* (API).
VITE_API_URL=https://api.estimat.example
