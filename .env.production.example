# EstiMat — production окружение (single-VPS baseline).
# Скопируйте в .env.production на VPS, заполните реальными значениями, права 600.
# НЕ коммитить (.env* в .gitignore и .dockerignore). Секреты — в защищённом хранилище (§18).

NODE_ENV=production
PORT=3000

# --- Yandex Managed PostgreSQL (§7). TLS обязателен. ---
DB_HOST=c-<cluster-id>.rw.mdb.yandexcloud.net
DB_PORT=6432
DB_NAME=estimat
DB_USER=estimat_runtime
DB_PASSWORD=<сильный-пароль-runtime-пользователя>
DB_SSL=true
# Примечание: миграции накатываются отдельным шагом пользователем estimat_migration (DDL).
# Если runtime-пользователь без DDL-прав — для шага migrate используйте отдельный .env
# с DB_USER=estimat_migration или временно повысьте права.

# --- JWT (standalone auth, §13). Сгенерируйте случайные строки ≥ 32 символов: ---
#   openssl rand -base64 48
JWT_SECRET=<random-min-32-chars>
JWT_REFRESH_SECRET=<random-min-32-chars-другой>

# --- CORS (§23): origin фронтенда (раздельные домены app.* / api.*). ---
CORS_ORIGIN=https://app.estimat.example

# --- S3 Cloud.ru (§15): хранение файлов (обложки проектов и пр.). Обязательно в проде. ---
S3_ENDPOINT=https://s3.cloud.ru
S3_REGION=ru-central-1
S3_ACCESS_KEY=<access-key>
S3_SECRET_KEY=<secret-key>
S3_BUCKET=estimat-files

# --- Портал РД (RDLOCAL, read-only) — опционально (§ интеграции). ---
RD_SUPABASE_URL=
RD_SUPABASE_KEY=
RD_R2_ENDPOINT=
RD_R2_ACCESS_KEY_ID=
RD_R2_SECRET_ACCESS_KEY=
RD_R2_BUCKET=

# --- ИИ-извлекатель (отложено) — опционально. ---
AI_OPENROUTER_API_KEY=
AI_OPENROUTER_MODEL=google/gemini-2.5-flash
AI_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Сборка фронтенда (build-arg, не runtime) ---
# Перед `docker compose ... build` экспортируйте абсолютный origin API:
#   export VITE_API_URL=https://api.estimat.example
